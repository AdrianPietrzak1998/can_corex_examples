PROJECT_NAME           = "CAN CoreX"
PROJECT_BRIEF          = "Table-driven CAN, CAN FD, ISO-TP, network simulation, and bus monitoring library"
PROJECT_NUMBER         = 2.2.2

OUTPUT_DIRECTORY       = docs
CREATE_SUBDIRS         = NO

INPUT                  = README.md \
                         can_corex.h \
                         can_corex_isotp.h \
                         can_corex_net.h \
                         can_corex_bus.h
USE_MDFILE_AS_MAINPAGE = README.md
FILE_PATTERNS          = *.h *.md
RECURSIVE              = NO

OPTIMIZE_OUTPUT_FOR_C  = YES
MARKDOWN_SUPPORT       = YES
AUTOLINK_SUPPORT       = YES

EXTRACT_ALL            = NO
EXTRACT_STATIC         = NO
HIDE_UNDOC_MEMBERS     = NO
HIDE_UNDOC_CLASSES     = NO
SHOW_INCLUDE_FILES     = YES
FULL_PATH_NAMES        = NO

GENERATE_HTML          = YES
HTML_OUTPUT            = html
GENERATE_LATEX         = NO
GENERATE_XML           = NO

ENABLE_PREPROCESSING   = YES
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = DOXYGEN=1 \
                         CCX_ENABLE_CANFD=1

WARNINGS               = YES
WARN_IF_UNDOCUMENTED   = NO
WARN_IF_DOC_ERROR      = NO
WARN_NO_PARAMDOC       = NO
WARN_AS_ERROR          = NO

QUIET                  = NO
JAVADOC_AUTOBRIEF      = YES
MULTILINE_CPP_IS_BRIEF = NO
